{
	"name": "humboldt-fish",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:clean": "pkill -f 'vite dev' 2>/dev/null; sleep 0.2; vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"smoke": "tsx scripts/smoke.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/suncalc": "^1.9.2",
		"autoprefixer": "^10.5.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.14",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^3.4.19",
		"tsx": "^4.22.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.6",
		"wrangler": "^4.92.0"
	},
	"dependencies": {
		"suncalc": "^1.9.0",
		"zod": "^4.4.3"
	}
}
